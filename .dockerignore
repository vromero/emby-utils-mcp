# Keep the build context small and stable.
# The Dockerfile consumes: package.json, package-lock.json*, tsconfig*.json,
# src/, and the docker/ staging directory. Everything else is excluded.

# VCS
.git
.gitignore

# CI / hooks
.github
.husky

# IDE
.vscode
.idea

# Changesets + changelog metadata
.changeset

# Build / test artefacts
node_modules
dist
coverage

# Tests (image is runtime-only)
tests
vitest.config.ts

# Linter + formatter configs (not needed inside the build)
eslint.config.js
.prettierrc.json
.prettierignore

# Docker itself
Dockerfile
.dockerignore
docker-compose.yml

# Documentation
AGENTS.md
README.md

# Environment
.env
.env.local
.env.*.local

# Logs + OS noise
*.log
.DS_Store
Thumbs.db
