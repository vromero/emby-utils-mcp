{
  "name": "@emby-utils/server",
  "version": "0.1.0",
  "description": "Model Context Protocol (MCP) server exposing the full Emby API over HTTP (Streamable HTTP + SSE).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "emby-mcp-server": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p config/tsconfig.build.json",
    "start": "node dist/bin.js",
    "test": "vitest run --config config/vitest.config.ts",
    "test:watch": "vitest --config config/vitest.config.ts",
    "clean": "node -e \"import('node:fs').then(f=>f.rmSync('dist',{recursive:true,force:true}))\"",
    "lint": "eslint -c config/eslint.config.js .",
    "lint:fix": "eslint -c config/eslint.config.js . --fix",
    "format": "prettier --config config/prettier.config.mjs --ignore-path config/.prettierignore --write .",
    "format:check": "prettier --config config/prettier.config.mjs --ignore-path config/.prettierignore --check .",
    "docker:build": "docker build -f docker/Dockerfile -t emby-utils-mcp:dev .",
    "docker:up": "docker compose -f docker/docker-compose.yml --project-directory docker up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml --project-directory docker down",
    "changeset": "changeset",
    "version": "changeset version && npm install --package-lock-only",
    "release": "npm run build && changeset publish",
    "release:dry": "npm run build && npm publish --dry-run --access public",
    "prepare": "husky .config/husky"
  },
  "lint-staged": {
    "*.{ts,js,mjs}": [
      "eslint -c config/eslint.config.js --fix",
      "prettier --config config/prettier.config.mjs --ignore-path config/.prettierignore --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --config config/prettier.config.mjs --ignore-path config/.prettierignore --write"
    ]
  },
  "engines": {
    "node": ">=22.13"
  },
  "dependencies": {
    "@emby-utils/client": "github:vromero/emby-utils-client#main",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.0 || ^4.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "msw": "^2.13.4",
    "prettier": "^3.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "emby",
    "mcp",
    "model-context-protocol",
    "ai"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vromero/emby-utils-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/vromero/emby-utils-mcp/issues"
  },
  "homepage": "https://github.com/vromero/emby-utils-mcp#readme"
}
