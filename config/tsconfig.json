{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": ["node"],
    // Paths resolve relative to this file, which lives in config/. The
    // repo-root `src/` and `dist/` are one level up.
    "outDir": "../dist",
    "rootDir": "../src"
  },
  "include": ["../src/**/*"]
}
