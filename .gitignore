# Dependencies
node_modules/

# Build artefacts
dist/
coverage/
*.tsbuildinfo

# Logs
*.log
npm-debug.log*

# Environment
.env
.env.local
.env.*.local

# Editor
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/

# OS
.DS_Store
Thumbs.db

# Test artefacts
*.msw-cache

# `local/` is a staging directory for ephemeral build inputs (e.g. a
# @emby-utils/client .tgz produced by `npm pack`). Only README.md and
# .gitkeep are tracked.
local/*
!local/README.md
!local/.gitkeep

# Compose reads docker/.env (adjacent to docker/docker-compose.yml).
docker/.env

# The .husky/ directory is no longer used; husky hooks now live in
# .config/husky/ (see the `prepare` script in package.json).

